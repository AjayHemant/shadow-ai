[
    {
        "name": "OpenAI API Key",
        "pattern": "\\bsk-(?:proj-)?[A-Za-z0-9_-]{32,64}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "OpenAI API key detected",
        "ignore_case": false
    },
    {
        "name": "Anthropic API Key",
        "pattern": "\\bsk-ant-[A-Za-z0-9_-]{32,64}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Anthropic Claude API key detected",
        "ignore_case": false
    },
    {
        "name": "HuggingFace Token",
        "pattern": "\\bhf_[A-Za-z0-9]{30,64}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "HuggingFace API token detected",
        "ignore_case": false
    },
    {
        "name": "AWS Access Key",
        "pattern": "\\bAKIA[0-9A-Z]{16}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "AWS Access Key ID detected",
        "ignore_case": false
    },
    {
        "name": "AWS Secret Key",
        "pattern": "\\b(?:aws[_-]?secret|aws[_-]?secret[_-]?access[_-]?key)\\s*[:=]\\s*[\"']?([A-Za-z0-9/+=]{40})[\"']?",
        "group": 1,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "AWS Secret Access Key detected",
        "ignore_case": true
    },
    {
        "name": "Google / Firebase API Key",
        "pattern": "\\bAIza[0-9A-Za-z_-]{35}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Google or Firebase API key detected",
        "ignore_case": false
    },
    {
        "name": "GitHub Token",
        "pattern": "\\bgh[pousr]_[A-Za-z0-9_]{36,255}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "GitHub personal access token detected",
        "ignore_case": false
    },
    {
        "name": "Slack Token",
        "pattern": "\\bxox[baprs]-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24,34}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Slack token detected",
        "ignore_case": false
    },
    {
        "name": "JWT Token",
        "pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b",
        "group": 0,
        "severity": "HIGH",
        "action": "BLOCK",
        "description": "JSON Web Token (JWT) detected",
        "ignore_case": false
    },
    {
        "name": "Private Key (PEM)",
        "pattern": "-----BEGIN (?:RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "PEM private key block detected",
        "ignore_case": false
    },
    {
        "name": "Generic API Key",
        "pattern": "\\b(?:api[_-]?key|access[_-]?token|secret[_-]?key|auth[_-]?token)\\s*[:=]\\s*[\"']?([A-Za-z0-9_=\\.-]{16,64})[\"']?",
        "group": 1,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Generic API key or token detected",
        "ignore_case": true
    },
    {
        "name": "Password in Payload",
        "pattern": "\\b(?:password|passwd|pwd)\\s*[:=]\\s*[\"']?([^\"'\\s=]{8,64})[\"']?",
        "group": 1,
        "severity": "HIGH",
        "action": "BLOCK",
        "description": "Password field value detected",
        "ignore_case": true
    },
    {
        "name": "Email Address",
        "pattern": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
        "group": 0,
        "severity": "MEDIUM",
        "action": "WARN",
        "description": "Email address detected",
        "ignore_case": false
    },
    {
        "name": "Credit Card Number",
        "pattern": "\\b(4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(?:011|5[0-9]{2})[0-9]{12})\\b",
        "group": 1,
        "severity": "HIGH",
        "action": "BLOCK",
        "description": "Credit card number pattern detected",
        "ignore_case": false
    },
    {
        "name": "International Phone Number",
        "pattern": "\\+?[1-9][0-9]{6,14}\\b",
        "group": 0,
        "severity": "MEDIUM",
        "action": "WARN",
        "description": "International phone number detected (E.164)",
        "ignore_case": false
    },
    {
        "name": "Stripe Secret Key",
        "pattern": "\\bsk_live_[0-9a-zA-Z]{24}\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Stripe live secret key detected",
        "ignore_case": false
    },
    {
        "name": "MongoDB Connection String",
        "pattern": "mongodb(?:\\+srv)?://[^:]+:[^@]+@",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "MongoDB credentials in connection string",
        "ignore_case": false
    },
    {
        "name": "Azure Storage Key",
        "pattern": "\\b[A-Za-z0-9+/]{86}==\\b",
        "group": 0,
        "severity": "CRITICAL",
        "action": "BLOCK",
        "description": "Azure storage account key detected",
        "ignore_case": false
    }
]